<%- include('partials/header') %>

<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-brasil-blue mb-6 text-center">Cadastro</h1>

  <% if (erro) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= erro %></div>
  <% } %>

  <form method="POST" action="/registro" class="bg-white rounded-xl shadow p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Nome completo</label>
      <input type="text" name="nome" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brasil-blue">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
      <input type="email" name="email" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brasil-blue">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Senha</label>
      <input type="password" name="senha" required minlength="4" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brasil-blue">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Confirmar senha</label>
      <input type="password" name="confirmarSenha" required minlength="4" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brasil-blue">
    </div>
    <button type="submit" class="w-full bg-brasil-green text-white py-2 rounded-lg font-semibold hover:bg-green-700 transition">Cadastrar</button>
  </form>

  <p class="text-center text-sm text-gray-500 mt-4">
    Já tem conta? <a href="/login" class="text-brasil-blue font-semibold hover:underline">Entrar</a>
  </p>
</div>

<%- include('partials/footer') %>
