<%- include('partials/header') %>

<div class="animate-fade-in-up">
  <h1 class="text-2xl font-bold text-copa-dark mb-6">Ranking</h1>

  <% if (!convocacaoPublicada) { %>
    <div class="bg-amber-50 border border-amber-200 text-amber-700 px-4 py-3 rounded-xl text-sm mb-4">
      O ranking será exibido após a convocação oficial ser publicada.
    </div>
  <% } else if (ranking.length === 0) { %>
    <p class="text-gray-500">Nenhuma aposta registrada ainda.</p>
  <% } else { %>
    <div class="card-copa overflow-hidden overflow-x-auto">
      <table class="w-full table-copa">
        <thead>
          <tr>
            <th class="px-4 py-3 text-left">#</th>
            <th class="px-4 py-3 text-left">Participante</th>
            <th class="px-4 py-3 text-center">Acertos</th>
            <th class="px-4 py-3 text-center">Pontuação</th>
            <th class="px-4 py-3 text-center">Índice Inusitado</th>
            <th class="px-4 py-3 text-center">Pagamento</th>
            <th class="px-4 py-3 text-center">Aposta</th>
          </tr>
        </thead>
        <tbody>
          <% ranking.forEach((r, i) => { %>
            <tr class="border-b hover:bg-gray-50 <%= i < 3 ? 'font-semibold' : '' %>">
              <td class="px-4 py-3">
                <% if (i === 0) { %>
                  <span class="text-xl">🥇</span>
                <% } else if (i === 1) { %>
                  <span class="text-xl">🥈</span>
                <% } else if (i === 2) { %>
                  <span class="text-xl">🥉</span>
                <% } else { %>
                  <%= r.posicao %>
                <% } %>
              </td>
              <td class="px-4 py-3"><%= r.nome %></td>
              <td class="px-4 py-3 text-center"><%= r.acertos %>/26</td>
              <td class="px-4 py-3 text-center font-bold text-copa-dark"><%= r.pontuacao %></td>
              <td class="px-4 py-3 text-center text-sm text-gray-600"><%= r.indiceInusitado %></td>
              <td class="px-4 py-3 text-center">
                <span class="text-xs px-2 py-1 rounded-full <%= r.status_pagamento === 'pago' ? 'badge-pago' : 'badge-pendente' %>">
                  <%= r.status_pagamento === 'pago' ? 'Pago' : 'Pendente' %>
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <% if (prazoExpirado) { %>
                  <a href="/apostas/<%= r.usuario_id %>" class="text-copa-dark hover:underline text-sm">Ver</a>
                <% } else { %>
                  <span class="text-gray-400 text-sm">Travada</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
