<%- include('../partials/header') %>

<div class="animate-fade-in-up">
  <div class="flex items-center gap-4 mb-6">
    <a href="/admin" class="text-copa-dark hover:underline text-sm">&larr; Voltar</a>
    <h1 class="text-2xl font-bold text-copa-dark">Gerenciar Pagamentos</h1>
  </div>

  <% if (sucesso) { %>
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm mb-4"><%= sucesso %></div>
  <% } %>

  <% if (usuarios.length === 0) { %>
    <p class="text-gray-500">Nenhum participante cadastrado.</p>
  <% } else { %>
    <div class="card-copa overflow-hidden">
      <table class="w-full table-copa">
        <thead>
          <tr>
            <th class="px-4 py-3 text-left">Nome</th>
            <th class="px-4 py-3 text-left">Email</th>
            <th class="px-4 py-3 text-center">Status</th>
            <th class="px-4 py-3 text-center">Data Pagamento</th>
            <th class="px-4 py-3 text-center">Ação</th>
          </tr>
        </thead>
        <tbody>
          <% usuarios.forEach(u => { %>
            <tr class="border-b hover:bg-gray-50">
              <td class="px-4 py-3 font-medium"><%= u.nome %></td>
              <td class="px-4 py-3 text-sm text-gray-600"><%= u.email %></td>
              <td class="px-4 py-3 text-center">
                <span class="text-xs px-2 py-1 rounded-full <%= u.status_pagamento === 'pago' ? 'badge-pago' : 'badge-pendente' %>">
                  <%= u.status_pagamento === 'pago' ? 'Pago' : 'Pendente' %>
                </span>
              </td>
              <td class="px-4 py-3 text-center text-sm text-gray-600">
                <%= u.data_pagamento ? new Date(u.data_pagamento).toLocaleDateString('pt-BR') : '-' %>
              </td>
              <td class="px-4 py-3 text-center">
                <form method="POST" action="/admin/pagamentos/<%= u.id %>" class="inline">
                  <% if (u.status_pagamento === 'pendente') { %>
                    <input type="hidden" name="status" value="pago">
                    <button type="submit" class="btn-copa btn-teal !py-1 !px-3 text-xs">
                      Confirmar pagamento
                    </button>
                  <% } else { %>
                    <input type="hidden" name="status" value="pendente">
                    <button type="submit" class="btn-copa btn-coral !py-1 !px-3 text-xs">
                      Desfazer
                    </button>
                  <% } %>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
