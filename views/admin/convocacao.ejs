<%- include('../partials/header') %>

<div class="flex items-center gap-4 mb-6">
  <a href="/admin" class="text-brasil-blue hover:underline text-sm">&larr; Voltar</a>
  <h1 class="text-2xl font-bold text-brasil-blue">Convocação Oficial</h1>
</div>

<% if (erro) { %>
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= erro %></div>
<% } %>
<% if (sucesso) { %>
  <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4"><%= sucesso %></div>
<% } %>

<form method="POST" action="/admin/convocacao" id="convocacaoForm">
  <input type="hidden" name="jogadores" id="jogadoresConvocadosInput" value='<%= JSON.stringify(jogadoresConvocados) %>'>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow p-6">
      <h2 class="text-lg font-semibold mb-3">Buscar jogador</h2>
      <input type="text" id="buscaConvocacao" placeholder="Digite o nome do jogador..."
        class="w-full border border-gray-300 rounded-lg px-3 py-2 mb-3 focus:outline-none focus:ring-2 focus:ring-brasil-blue">
      <div id="resultadosBuscaConvocacao" class="max-h-96 overflow-y-auto space-y-1"></div>
    </div>

    <div class="bg-white rounded-xl shadow p-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold">Convocados</h2>
        <span id="contagemConvocacao" class="text-sm font-bold px-3 py-1 rounded-full
          <%= jogadoresConvocados.length === 26 ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
          <%= jogadoresConvocados.length %>/26
        </span>
      </div>
      <div id="listaConvocados" class="space-y-1 max-h-96 overflow-y-auto"></div>
    </div>
  </div>

  <div class="mt-6 text-center">
    <button type="submit" id="btnSalvarConvocacao"
      class="bg-brasil-green text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-green-700 transition disabled:opacity-50 disabled:cursor-not-allowed"
      <%= jogadoresConvocados.length !== 26 ? 'disabled' : '' %>>
      Salvar convocação oficial
    </button>
  </div>
</form>

<script>
  const jogadoresConvocadosAdmin = <%= JSON.stringify(jogadoresConvocados) %>;
</script>

<%- include('../partials/footer') %>
