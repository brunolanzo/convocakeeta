<%- include('../partials/header') %>

<div class="animate-fade-in-up">
  <div class="flex items-center gap-4 mb-6">
    <a href="/admin" class="text-copa-dark hover:underline text-sm">&larr; Voltar</a>
    <h1 class="text-2xl font-bold text-copa-dark">Convocação Oficial</h1>
  </div>

  <% if (erro) { %>
    <div class="bg-red-50 border border-red-200 text-copa-coral px-4 py-3 rounded-xl text-sm mb-4"><%= erro %></div>
  <% } %>
  <% if (sucesso) { %>
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm mb-4"><%= sucesso %></div>
  <% } %>

  <form method="POST" action="/admin/convocacao" id="convocacaoForm">
    <input type="hidden" name="jogadores" id="jogadoresConvocadosInput" value='<%= JSON.stringify(jogadoresConvocados) %>'>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="card-copa p-6">
        <h2 class="text-lg font-semibold mb-3">Buscar jogador</h2>
        <input type="text" id="buscaConvocacao" placeholder="Digite o nome do jogador..."
          class="w-full input-copa mb-3">
        <div id="resultadosBuscaConvocacao" class="max-h-96 overflow-y-auto space-y-1"></div>
      </div>

      <div class="card-copa p-6">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-semibold">Convocados</h2>
          <span id="contagemConvocacao" class="text-sm font-bold px-3 py-1 rounded-full
            <%= jogadoresConvocados.length === 26 ? 'badge-pago' : 'bg-amber-50 border border-amber-200 text-amber-700' %>">
            <%= jogadoresConvocados.length %>/26
          </span>
        </div>
        <div id="listaConvocados" class="space-y-1 max-h-96 overflow-y-auto"></div>
      </div>
    </div>

    <div class="mt-6 text-center">
      <button type="submit" id="btnSalvarConvocacao"
        class="btn-copa btn-teal px-8 py-3 text-lg disabled:opacity-50 disabled:cursor-not-allowed"
        <%= jogadoresConvocados.length !== 26 ? 'disabled' : '' %>>
        Salvar convocação oficial
      </button>
    </div>
  </form>
</div>

<script>
  const jogadoresConvocadosAdmin = <%= JSON.stringify(jogadoresConvocados) %>;
</script>

<%- include('../partials/footer') %>
