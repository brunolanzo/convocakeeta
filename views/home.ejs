<%- include('partials/header') %>

<!-- Hero Section Clean -->
<section class="hero-clean -mx-4 -mt-8 mb-12 relative overflow-hidden">
  <div class="hero-clean-content relative z-10 px-4 py-20 md:py-28 max-w-3xl mx-auto text-center">
    <div class="animate-fade-in-up">
      <span class="inline-block px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-5 hero-badge">
        Copa do Mundo 2026
      </span>
    </div>
    <h1 class="text-5xl md:text-7xl font-black text-white mb-4 animate-fade-in-up animate-delay-100 leading-[1.1]">
      Bolão da Convocação
    </h1>
    <p class="text-lg md:text-xl text-gray-400 mb-10 animate-fade-in-up animate-delay-200 max-w-xl mx-auto">
      Monte sua seleção com os 26 convocados
    </p>
    <div class="flex flex-wrap gap-3 justify-center animate-fade-in-up animate-delay-300">
      <% if (user) { %>
        <a href="/apostas" class="btn-copa btn-teal text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Fazer minha aposta
        </a>
        <a href="/ranking" class="btn-copa btn-glass text-lg">
          Ver ranking
        </a>
      <% } else { %>
        <a href="/registro" class="btn-copa btn-teal text-lg">
          Cadastrar e participar
        </a>
        <a href="/login" class="btn-copa btn-glass text-lg">
          Já tenho conta
        </a>
      <% } %>
    </div>
  </div>
</section>

<!-- Stats Cards -->
<div class="grid grid-cols-3 gap-4 md:gap-6 mb-12">
  <div class="card-copa card-copa-color card-teal p-5 md:p-6 text-center animate-fade-in-up animate-delay-100">
    <div class="stat-number mb-1">26</div>
    <div class="text-gray-500 text-sm font-medium">Jogadores</div>
  </div>
  <div class="card-copa card-copa-color card-coral p-5 md:p-6 text-center animate-fade-in-up animate-delay-200">
    <div class="stat-number coral mb-1">260</div>
    <div class="text-gray-500 text-sm font-medium">Pontos máximos</div>
  </div>
  <div class="card-copa card-copa-color card-purple p-5 md:p-6 text-center animate-fade-in-up animate-delay-300">
    <div class="stat-number purple mb-1"><%= totalParticipantes %></div>
    <div class="text-gray-500 text-sm font-medium">Participantes</div>
  </div>
</div>

<!-- Countdown -->
<% if (prazo) { %>
<div class="countdown-box rounded-2xl p-6 md:p-8 mb-12 text-center animate-fade-in-up">
  <p class="text-gray-400 text-sm font-medium uppercase tracking-wider mb-3">Prazo para enviar sua aposta</p>
  <div id="countdown" class="countdown-number" data-prazo="<%= prazo %>"></div>
  <p class="text-gray-500 text-xs mt-3">
    <%= new Date(prazo).toLocaleString('pt-BR', { dateStyle: 'long', timeStyle: 'short' }) %>
  </p>
</div>
<% } %>

<!-- Premiação -->
<% const premioTotal = totalParticipantes * 50; %>
<div class="card-copa p-0 mb-12 overflow-hidden animate-fade-in-up" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
  <div class="p-6 md:p-8">
    <div class="text-center mb-6">
      <span class="text-3xl mb-2 block">🏆</span>
      <h2 class="text-2xl md:text-3xl font-black text-white">Premiação</h2>
      <p class="text-gray-400 text-sm mt-1"><%= totalParticipantes %> participante<%= totalParticipantes !== 1 ? 's' : '' %> &bull; Prêmio total: <span class="text-copa-teal font-bold">R$ <%= premioTotal.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span></p>
    </div>
    <div class="grid grid-cols-3 gap-3 md:gap-6">
      <!-- 1º Lugar -->
      <div class="text-center relative">
        <div class="w-16 h-16 md:w-20 md:h-20 mx-auto rounded-full bg-gradient-to-br from-amber-400 to-yellow-500 flex items-center justify-center mb-3 shadow-lg shadow-amber-500/20">
          <span class="text-2xl md:text-3xl font-black text-white">1º</span>
        </div>
        <div class="text-2xl md:text-3xl font-black text-amber-400 mb-1">R$ <%= Math.floor(premioTotal * 0.7).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        <div class="text-xs text-gray-400 font-medium uppercase tracking-wider">70% do prêmio</div>
      </div>
      <!-- 2º Lugar -->
      <div class="text-center relative">
        <div class="w-14 h-14 md:w-16 md:h-16 mx-auto rounded-full bg-gradient-to-br from-gray-300 to-gray-400 flex items-center justify-center mb-3 shadow-lg shadow-gray-400/20">
          <span class="text-xl md:text-2xl font-black text-white">2º</span>
        </div>
        <div class="text-xl md:text-2xl font-black text-gray-300 mb-1">R$ <%= Math.floor(premioTotal * 0.2).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        <div class="text-xs text-gray-400 font-medium uppercase tracking-wider">20% do prêmio</div>
      </div>
      <!-- 3º Lugar -->
      <div class="text-center relative">
        <div class="w-12 h-12 md:w-14 md:h-14 mx-auto rounded-full bg-gradient-to-br from-amber-600 to-amber-700 flex items-center justify-center mb-3 shadow-lg shadow-amber-700/20">
          <span class="text-lg md:text-xl font-black text-white">3º</span>
        </div>
        <div class="text-lg md:text-xl font-black text-amber-600 mb-1">R$ <%= Math.floor(premioTotal * 0.1).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        <div class="text-xs text-gray-400 font-medium uppercase tracking-wider">10% do prêmio</div>
      </div>
    </div>
  </div>
</div>

<!-- Preview Cards - Simulação das seções internas -->
<h2 class="text-2xl md:text-3xl font-bold text-copa-dark mb-6 animate-fade-in-up">
  Como funciona
</h2>
<div class="grid md:grid-cols-3 gap-6 mb-12">

  <!-- Card 1: Aposta na Escalação -->
  <div class="preview-card card-copa p-0 animate-fade-in-up animate-delay-100 cursor-pointer group flex flex-col" onclick="window.location='/apostas'">
    <div class="preview-card-screen bg-gradient-to-br from-slate-900 to-slate-800 p-4 rounded-t-2xl relative overflow-hidden flex-shrink-0">
      <div class="preview-card-header flex items-center gap-2 mb-3">
        <div class="w-2 h-2 rounded-full bg-red-400"></div>
        <div class="w-2 h-2 rounded-full bg-yellow-400"></div>
        <div class="w-2 h-2 rounded-full bg-green-400"></div>
        <span class="text-[10px] text-gray-500 ml-2">Minha Aposta</span>
      </div>
      <!-- Simulação de busca de jogador -->
      <div class="bg-white/10 rounded-lg p-2 mb-2 backdrop-blur">
        <div class="flex items-center gap-2">
          <svg class="w-3 h-3 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <span class="text-[10px] text-gray-400 typing-animation">Buscar jogador...</span>
        </div>
      </div>
      <!-- Jogadores simulados com animação -->
      <div class="space-y-1.5">
        <div class="preview-player preview-player-1 flex items-center gap-2 bg-white/5 rounded-lg px-2 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0"></span>
          <span class="text-[10px] text-white font-medium">Alisson</span>
          <span class="text-[8px] text-gray-400 ml-auto">Goleiro</span>
        </div>
        <div class="preview-player preview-player-2 flex items-center gap-2 bg-white/5 rounded-lg px-2 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0"></span>
          <span class="text-[10px] text-white font-medium">Marquinhos</span>
          <span class="text-[8px] text-gray-400 ml-auto">Zagueiro</span>
        </div>
        <div class="preview-player preview-player-3 flex items-center gap-2 bg-white/5 rounded-lg px-2 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
          <span class="text-[10px] text-white font-medium">Vinícius Jr</span>
          <span class="text-[8px] text-gray-400 ml-auto">Atacante</span>
        </div>
        <div class="preview-player preview-player-4 flex items-center gap-2 bg-teal-500/20 rounded-lg px-2 py-1.5 border border-teal-500/30">
          <span class="w-1.5 h-1.5 rounded-full bg-purple-400 flex-shrink-0"></span>
          <span class="text-[10px] text-teal-300 font-medium">Rodrygo</span>
          <span class="text-[8px] text-teal-400 ml-auto">+ Adicionar</span>
        </div>
      </div>
      <!-- Barra de progresso simulada -->
      <div class="mt-3">
        <div class="flex justify-between text-[8px] text-gray-400 mb-1">
          <span>Selecionados</span>
          <span class="counter-sim">12/26</span>
        </div>
        <div class="h-1 bg-white/10 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-teal-400 to-lime-400 rounded-full progress-animate" style="width: 46%"></div>
        </div>
      </div>
    </div>
    <div class="p-5 flex-1 flex flex-col justify-center">
      <h3 class="font-bold text-copa-dark text-lg mb-1 group-hover:text-copa-teal transition">Monte sua Escalação</h3>
      <p class="text-gray-500 text-sm">Escolha 26 jogadores entre goleiros, defensores, meias e atacantes para sua convocação.</p>
    </div>
  </div>

  <!-- Card 2: Ranking -->
  <div class="preview-card card-copa p-0 animate-fade-in-up animate-delay-200 cursor-pointer group flex flex-col" onclick="window.location='/ranking'">
    <div class="preview-card-screen bg-gradient-to-br from-slate-900 to-slate-800 p-4 rounded-t-2xl relative overflow-hidden flex-shrink-0">
      <div class="preview-card-header flex items-center gap-2 mb-3">
        <div class="w-2 h-2 rounded-full bg-red-400"></div>
        <div class="w-2 h-2 rounded-full bg-yellow-400"></div>
        <div class="w-2 h-2 rounded-full bg-green-400"></div>
        <span class="text-[10px] text-gray-500 ml-2">Ranking</span>
      </div>
      <!-- Pódio simulado -->
      <div class="flex items-end justify-center gap-2 mb-3 h-16">
        <div class="rank-bar rank-bar-2 w-10 bg-gradient-to-t from-gray-400 to-gray-300 rounded-t-lg flex flex-col items-center justify-start pt-1" style="height: 70%">
          <span class="text-[8px] font-bold text-white">2º</span>
          <span class="text-[7px] text-white/80 mt-0.5">180</span>
        </div>
        <div class="rank-bar rank-bar-1 w-10 bg-gradient-to-t from-amber-500 to-yellow-400 rounded-t-lg flex flex-col items-center justify-start pt-1" style="height: 100%">
          <span class="text-[10px]">🏆</span>
          <span class="text-[8px] font-bold text-white">1º</span>
          <span class="text-[7px] text-white/80">220</span>
        </div>
        <div class="rank-bar rank-bar-3 w-10 bg-gradient-to-t from-amber-700 to-amber-600 rounded-t-lg flex flex-col items-center justify-start pt-1" style="height: 55%">
          <span class="text-[8px] font-bold text-white">3º</span>
          <span class="text-[7px] text-white/80 mt-0.5">150</span>
        </div>
      </div>
      <!-- Tabela simulada -->
      <div class="space-y-1">
        <div class="flex items-center gap-2 bg-white/5 rounded px-2 py-1 rank-row rank-row-1">
          <span class="text-[9px] text-amber-400 font-bold w-3">4</span>
          <span class="text-[9px] text-white">Carlos M.</span>
          <span class="text-[9px] text-teal-400 ml-auto font-mono">140</span>
        </div>
        <div class="flex items-center gap-2 bg-white/5 rounded px-2 py-1 rank-row rank-row-2">
          <span class="text-[9px] text-gray-400 font-bold w-3">5</span>
          <span class="text-[9px] text-white">Ana P.</span>
          <span class="text-[9px] text-teal-400 ml-auto font-mono">130</span>
        </div>
        <div class="flex items-center gap-2 bg-white/5 rounded px-2 py-1 rank-row rank-row-3">
          <span class="text-[9px] text-gray-400 font-bold w-3">6</span>
          <span class="text-[9px] text-white">Pedro S.</span>
          <span class="text-[9px] text-teal-400 ml-auto font-mono">120</span>
        </div>
      </div>
    </div>
    <div class="p-5 flex-1 flex flex-col justify-center">
      <h3 class="font-bold text-copa-dark text-lg mb-1 group-hover:text-copa-teal transition">Acompanhe o Ranking</h3>
      <p class="text-gray-500 text-sm">Veja quem está na frente, compare pontuações e acompanhe o critério de desempate inusitado.</p>
    </div>
  </div>

  <!-- Card 3: Estatísticas -->
  <div class="preview-card card-copa p-0 animate-fade-in-up animate-delay-300 cursor-pointer group flex flex-col" onclick="window.location='/estatisticas'">
    <div class="preview-card-screen bg-gradient-to-br from-slate-900 to-slate-800 p-4 rounded-t-2xl relative overflow-hidden flex-shrink-0">
      <div class="preview-card-header flex items-center gap-2 mb-3">
        <div class="w-2 h-2 rounded-full bg-red-400"></div>
        <div class="w-2 h-2 rounded-full bg-yellow-400"></div>
        <div class="w-2 h-2 rounded-full bg-green-400"></div>
        <span class="text-[10px] text-gray-500 ml-2">Estatísticas</span>
      </div>
      <!-- Barras de estatística simuladas -->
      <div class="mb-3">
        <div class="text-[8px] text-gray-400 uppercase tracking-wider mb-2">Jogadores mais apostados</div>
        <div class="space-y-2">
          <div>
            <div class="flex justify-between text-[9px] mb-0.5">
              <span class="text-white">Vinícius Jr</span>
              <span class="text-teal-400">95%</span>
            </div>
            <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full rounded-full stat-bar stat-bar-1 bg-gradient-to-r from-teal-500 to-teal-400" style="width: 0%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-[9px] mb-0.5">
              <span class="text-white">Rodrygo</span>
              <span class="text-purple-400">88%</span>
            </div>
            <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full rounded-full stat-bar stat-bar-2 bg-gradient-to-r from-purple-500 to-purple-400" style="width: 0%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-[9px] mb-0.5">
              <span class="text-white">Alisson</span>
              <span class="text-orange-400">82%</span>
            </div>
            <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full rounded-full stat-bar stat-bar-3 bg-gradient-to-r from-orange-500 to-orange-400" style="width: 0%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-[9px] mb-0.5">
              <span class="text-white">Marquinhos</span>
              <span class="text-blue-400">76%</span>
            </div>
            <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full rounded-full stat-bar stat-bar-4 bg-gradient-to-r from-blue-500 to-blue-400" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </div>
      <!-- Mini donut chart simulado -->
      <div class="flex items-center gap-3 bg-white/5 rounded-lg p-2">
        <div class="w-8 h-8 rounded-full border-[3px] border-teal-400 border-t-purple-500 border-r-orange-400 spin-slow flex-shrink-0"></div>
        <div>
          <span class="text-[9px] text-white font-medium block">Distribuição por posição</span>
          <span class="text-[8px] text-gray-400">Atacantes lideram as apostas</span>
        </div>
      </div>
    </div>
    <div class="p-5 flex-1 flex flex-col justify-center">
      <h3 class="font-bold text-copa-dark text-lg mb-1 group-hover:text-copa-teal transition">Explore Estatísticas</h3>
      <p class="text-gray-500 text-sm">Descubra os jogadores mais apostados, posições favoritas e tendências do bolão.</p>
    </div>
  </div>
</div>

<!-- Regras -->
<h2 class="text-2xl md:text-3xl font-bold text-copa-dark mb-6 animate-fade-in-up">
  Regras do Bolão
</h2>
<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
  <!-- Regra 1 -->
  <div class="card-copa p-6 text-center animate-fade-in-up animate-delay-100 group hover:border-copa-teal/30">
    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-500/15 to-teal-500/5 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
      <svg class="w-7 h-7 text-copa-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
    </div>
    <h3 class="font-bold text-copa-dark text-lg mb-2">26 Jogadores</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Escolha exatamente 26 jogadores para montar sua convocação ideal.</p>
  </div>

  <!-- Regra 2 -->
  <div class="card-copa p-6 text-center animate-fade-in-up animate-delay-200 group hover:border-copa-coral/30">
    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-coral/15 to-coral/5 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
      <svg class="w-7 h-7 text-copa-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
    </div>
    <h3 class="font-bold text-copa-dark text-lg mb-2">10 Pontos</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Cada jogador correto na convocação oficial vale 10 pontos. Máximo: 260.</p>
  </div>

  <!-- Regra 3 -->
  <div class="card-copa p-6 text-center animate-fade-in-up animate-delay-300 group hover:border-copa-purple/30">
    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500/15 to-purple-500/5 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
      <svg class="w-7 h-7 text-copa-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
    </div>
    <h3 class="font-bold text-copa-dark text-lg mb-2">Índice Inusitado</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Critério de desempate que premia quem acertou jogadores que poucos apostaram.</p>
  </div>

  <!-- Regra 4 -->
  <div class="card-copa p-6 text-center animate-fade-in-up animate-delay-400 group hover:border-copa-orange/30">
    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-orange-500/15 to-orange-500/5 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
      <svg class="w-7 h-7 text-copa-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <h3 class="font-bold text-copa-dark text-lg mb-2">Edite até o Prazo</h3>
    <p class="text-gray-500 text-sm leading-relaxed">Altere sua aposta quantas vezes quiser até o encerramento do prazo.</p>
  </div>
</div>

<%- include('partials/footer') %>
