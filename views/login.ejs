<%- include('partials/header') %>

<div class="max-w-md mx-auto animate-fade-in-up">
  <h1 class="text-2xl font-bold text-copa-dark mb-6 text-center">Entrar</h1>

  <% if (erro) { %>
    <div class="bg-red-50 border border-red-200 text-copa-coral px-4 py-3 rounded-xl text-sm mb-4"><%= erro %></div>
  <% } %>

  <form method="POST" action="/login" class="card-copa p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
      <input type="email" name="email" required class="w-full input-copa">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Senha</label>
      <input type="password" name="senha" required class="w-full input-copa">
    </div>
    <button type="submit" class="w-full btn-copa btn-purple">Entrar</button>
  </form>

  <p class="text-center text-sm text-gray-500 mt-4">
    Não tem conta? <a href="/registro" class="text-copa-dark font-semibold hover:underline">Cadastre-se</a>
  </p>
</div>

<%- include('partials/footer') %>
