<%- include('../partials/header') %>

<h1 class="text-2xl font-bold text-brasil-blue mb-6">Minha Aposta</h1>

<% if (erro) { %>
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= erro %></div>
<% } %>
<% if (sucesso) { %>
  <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4"><%= sucesso %></div>
<% } %>

<% if (prazoExpirado) { %>
  <div class="bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-3 rounded mb-4">
    O prazo para apostas já encerrou. Sua lista está travada.
  </div>
<% } %>

<form method="POST" action="/apostas" id="apostaForm">
  <input type="hidden" name="jogadores" id="jogadoresInput" value='<%= JSON.stringify(jogadoresSelecionados) %>'>

  <div class="grid md:grid-cols-2 gap-6">
    <!-- Seletor de jogadores -->
    <div class="bg-white rounded-xl shadow p-6">
      <h2 class="text-lg font-semibold mb-3">Buscar jogador</h2>
      <% if (!prazoExpirado) { %>
        <input type="text" id="buscaJogador" placeholder="Digite o nome, posição ou clube..."
          class="w-full border border-gray-300 rounded-lg px-3 py-2 mb-3 focus:outline-none focus:ring-2 focus:ring-brasil-blue">
        <div id="resultadosBusca" class="max-h-96 overflow-y-auto space-y-1"></div>
      <% } else { %>
        <p class="text-gray-500 text-sm">Apostas travadas.</p>
      <% } %>
    </div>

    <!-- Lista selecionada -->
    <div class="bg-white rounded-xl shadow p-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold">Sua lista</h2>
        <span id="contagem" class="text-sm font-bold px-3 py-1 rounded-full
          <%= jogadoresSelecionados.length === 26 ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
          <%= jogadoresSelecionados.length %>/26
        </span>
      </div>
      <div id="listaSelecionados" class="space-y-1 max-h-96 overflow-y-auto"></div>
    </div>
  </div>

  <% if (!prazoExpirado) { %>
    <div class="mt-6 text-center">
      <button type="submit" id="btnSalvar"
        class="bg-brasil-green text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-green-700 transition disabled:opacity-50 disabled:cursor-not-allowed"
        <%= jogadoresSelecionados.length !== 26 ? 'disabled' : '' %>>
        Salvar aposta
      </button>
    </div>
  <% } %>
</form>

<script>
  const jogadoresSelecionados = <%= JSON.stringify(jogadoresSelecionados) %>;
  const prazoExpirado = <%= prazoExpirado %>;
</script>

<%- include('../partials/footer') %>
